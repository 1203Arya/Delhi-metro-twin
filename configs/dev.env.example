# ─────────────────────────────────────────────────────────────
# Delhi Metro Digital Twin — Development environment defaults
# Copy this file to configs/dev.env and fill in the secrets.
# NEVER commit the filled-in file.
# ─────────────────────────────────────────────────────────────

# ---- Runtime profile ----
ENVIRONMENT=development
LOG_LEVEL=DEBUG
TIME_SCALE=1.0                # simulation speed multiplier (1.0 = realtime)
SIM_TICK_SECONDS=0.5          # physics timestep in seconds of wall clock
SIM_DT_SECONDS=1.0            # simulated seconds advanced per tick
RANDOM_SEED=42

# ---- Postgres + PostGIS ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dmdt
POSTGRES_USER=dmdt
POSTGRES_PASSWORD=change-me-in-dev
POSTGRES_SCHEMA=public
DATABASE_URL=postgresql+asyncpg://dmdt:change-me-in-dev@postgres:5432/dmdt

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-me-in-dev
REDIS_URL=redis://dmdt:change-me-in-dev@redis:6379/0

# ---- RabbitMQ ----
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=dmdt
RABBITMQ_PASSWORD=change-me-in-dev
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://dmdt:change-me-in-dev@rabbitmq:5672/
# Topic exchanges + routing keys
RABBITMQ_TELEMETRY_EXCHANGE=dmdt.telemetry
RABBITMQ_EVENTS_EXCHANGE=dmdt.events
RABBITMQ_COMMANDS_EXCHANGE=dmdt.commands
RABBITMQ_TELEMETRY_ROUTING_KEY=telemetry.train
RABBITMQ_EVENTS_ROUTING_KEY=event.system

# ---- Backend (FastAPI) ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=600
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-dev
PROMETHEUS_PORT=9090

# ---- Simulation engine ----
SIM_HOST=simulation
SIM_GRPC_PORT=50051
SIM_WS_PORT=8090
SIM_TRAINS_INITIAL=120
SIM_PASSENGERS_PER_MINUTE_PEAK=9000
SIM_PASSENGERS_PER_MINUTE_OFFPEAK=1500
SIM_LINES_ENABLED=ALL

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE=ws://localhost:8000
NEXT_PUBLIC_MAP_TILE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=dmdt
SENTRY_DSN=

# ---- AI / prediction ----
AI_MODEL_DIR=/app/models
AI_PREDICTION_HORIZON_MINUTES=30
AI_FEATURE_CACHE_TTL=120
