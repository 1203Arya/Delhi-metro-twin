.env
*.env
!.env.example
configs/*.env
!configs/*.env.example
.env.local
.env.*.local

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# ---- Node / Next.js ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.pnp.*
.yarn/cache

# Next.js build / cache
.next/
out/
build/
next-env.d.ts

# Frontend test artifacts
coverage/
*.log
.eslintcache

# ---- TypeScript ----
*.tsbuildinfo

# ---- Docker / runtime ----
docker/data/
docker/volumes/
*.pid
*.seed
*.pid.lock

# ---- Databases ----
*.sqlite
*.sqlite3
*.db
postgres-data/
pgdata/

# ---- IDE / editors ----
.vscode/
!.vscode/settings.example.json
.idea/
*.swp
*.swo
*~
.DS_Store

# ---- OS ----
Thumbs.db
ehthumbs.db
Desktop.ini

