# ─────────────────────────────────────────────────────────────
# Delhi Metro Digital Twin — Environment Variables
# Copy this file to .env and fill in the values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ---- Postgres ----
POSTGRES_DB=dmdt
POSTGRES_USER=dmdt
POSTGRES_PASSWORD=change-me-in-dev
DATABASE_URL=postgresql+asyncpg://dmdt:change-me-in-dev@postgres:5432/dmdt

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- RabbitMQ ----
RABBITMQ_USER=dmdt
RABBITMQ_PASSWORD=change-me-in-dev
RABBITMQ_URL=amqp://dmdt:change-me-in-dev@rabbitmq:5672/

# ---- Backend ----
ENVIRONMENT=production
LOG_LEVEL=INFO
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-dev
CORS_ORIGINS=["*"]
RATE_LIMIT_PER_MINUTE=600

# ---- Simulation ----
SIM_TICK_SECONDS=0.5
SIM_DT_SECONDS=1.0
RANDOM_SEED=42
TIME_SCALE=1.0
SIM_TRAINS_INITIAL=120
SIM_PASSENGERS_PER_MINUTE_PEAK=9000
SIM_PASSENGERS_PER_MINUTE_OFFPEAK=1500
SIM_LINES_ENABLED=ALL

# ---- Frontend (NEXT_PUBLIC_* are baked at build time — defaults are relative) ----
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=/api/v1
NEXT_PUBLIC_MAP_TILE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# ---- Cloudflare Tunnel (named tunnel) — set after one-time tunnel create ----
TUNNEL_NAME=delhi-metro-twin
TUNNEL_UUID=
TUNNEL_HOSTNAME=   # e.g. <uuid>.cfargotunnel.com

# ---- Observability (optional — leave blank to disable) ----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=dmdt
SENTRY_DSN=
